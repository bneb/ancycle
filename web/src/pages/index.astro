---
import '../styles/global.css';

// Astro automatically renders this at build time (or SSR mode if enabled, but Pages handles it natively)
---
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Ancycle Cloud — Formal Verification for Data Pipelines</title>
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
</head>
<body class="min-h-screen pt-16 pb-32">
    <div class="max-w-5xl mx-auto px-6">
        
        {/* Header */}
        <header class="flex items-center justify-between mb-24 opacity-90">
            <div class="flex items-center gap-3">
                <img src="/logo.svg" alt="Ancycle" class="w-8 h-8 rounded shrink-0 object-contain shadow-sm" />
                <span class="font-extrabold text-2xl tracking-[-0.05em] text-white">ancycle</span>
            </div>
            <a
                href="https://github.com/bneb/ancycle"
                class="text-sm font-medium text-gray-400 hover:text-white transition-colors flex items-center gap-2"
            >
                GitHub
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
            </a>
        </header>

        {/* Hero Segment */}
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            
            <div class="flex flex-col gap-6 z-10 w-full">
                <h1 class="text-4xl md:text-5xl font-extrabold tracking-[-0.04em] text-balance leading-[1.15]">
                    Formal verification <br class="hidden md:block"/>
                    <span class="text-gray-400 font-medium">for data pipelines.</span>
                </h1>
                
                <p class="text-base text-gray-400 max-w-lg leading-relaxed mt-2">
                    Ancycle parses your SQL, builds a constraint model, and feeds it to the Z3 theorem prover. It finds logical contradictions in your DAG natively before any compute is provisioned.
                </p>
                
                <div class="mt-8">
                    <p class="text-xs text-gray-500 mb-4 font-mono uppercase tracking-wider">Early Access: Ancycle Cloud</p>
                    <form id="waitlist-form" class="relative max-w-sm">
                        <input
                            type="email"
                            required
                            placeholder="investor@sequoia.com"
                            class="w-full bg-[rgba(255,255,255,0.02)] border border-[rgba(255,255,255,0.1)] text-white text-sm rounded-lg px-4 py-3 focus:outline-none focus:border-gray-500 transition-colors placeholder:text-gray-600"
                        />
                        <button
                            type="submit"
                            class="absolute right-1.5 top-1.5 bottom-1.5 px-4 bg-white text-black text-sm font-semibold rounded-md hover:bg-gray-200 transition-colors"
                        >
                            Join Waitlist
                        </button>
                    </form>
                    <p id="waitlist-error" class="hidden text-red-500 text-xs mt-3 font-mono"></p>
                    
                    <div id="waitlist-success" class="hidden glass-card border-[rgba(39,201,63,0.3)] bg-[rgba(39,201,63,0.05)] border rounded-lg p-4 max-w-sm shadow-lg shadow-green-900/10 transition-all duration-300">
                        <div class="flex items-center gap-3">
                            <span class="flex h-6 w-6 rounded-full bg-green-500/20 items-center justify-center shrink-0">
                                <span class="h-2 w-2 rounded-full bg-green-500 animate-pulse shadow-[0_0_8px_theme(colors.green.500)]"></span>
                            </span>
                            <div>
                                <h3 class="text-sm font-bold text-green-400 tracking-wide">ACCESS GRANTED</h3>
                                <p class="text-xs text-green-500/70 mt-0.5">You are on the list. We'll deploy your API keys shortly.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            {/* Terminal Visual */}
            <div class="w-full relative group">
                <div class="absolute -inset-1 bg-gradient-to-r from-[var(--color-brand-blue)] to-[var(--color-brand-pink)] rounded-lg blur opacity-10 group-hover:opacity-20 transition duration-1000"></div>
                
                <div class="terminal-window relative font-mono text-sm shadow-2xl">
                    <div class="terminal-header">
                        <div class="terminal-dot dot-red"></div>
                        <div class="terminal-dot dot-yellow"></div>
                        <div class="terminal-dot dot-green"></div>
                        <div class="ml-2 text-xs text-gray-500 font-sans tracking-wide">bun src/cli/demo.ts</div>
                    </div>
                    
                    <div class="p-4 md:p-6 text-gray-300 flex flex-col gap-3 h-[350px] md:h-[400px] overflow-y-auto w-full max-w-full leading-relaxed text-xs md:text-sm">
                        <div class="text-gray-500 mb-2">$ ancycle verify pipelines/core.sql</div>
                        
                        <div>
                            <span class="text-[var(--color-brand-blue)]">Read</span> <span class="text-white">[stg_active_users]</span>: Constraints → <span class="text-green-400">(= status "active")</span>
                        </div>
                        
                        <div class="pl-0 animate-[fade-in_1s_ease-out_both] delay-500">
                            <span class="text-[var(--color-brand-blue)]">Read</span> <span class="text-white">[process_churned]</span>:  Depends on  → <span class="text-yellow-400">[stg_active_users]</span>
                        </div>
                        
                        <div class="pl-0 animate-[fade-in_1s_ease-out_both] delay-1000">
                            <span class="text-[var(--color-brand-blue)]">Read</span> <span class="text-white">[process_churned]</span>:  Constraints → <span class="text-red-400">(= status "churned")</span>
                        </div>
                        
                        <div class="mt-4 text-gray-600 animate-[fade-in_1s_ease-out_both] delay-1500">
                            Checking constraints with Z3 shadow...
                        </div>

                        <div class="mt-4 glass-card border-red-900/50 bg-red-950/20 p-4 border rounded animate-[fade-in_0.5s_ease-out_both] delay-[2500ms]">
                            <div class="text-red-400 font-bold mb-2">❌ FATAL: Z3 QF_S Resolution: UNSAT</div>
                            <div class="text-gray-300">
                                ↳ <span class="text-white">[process_churned]</span> is guaranteed to process 0 rows.
                            </div>
                            <div class="text-gray-400 mt-1">
                                Upstream and downstream filters are mutually exclusive.
                            </div>
                        </div>

                        <div class="mt-4 flex flex-col gap-1 animate-[fade-in_0.5s_ease-out_both] delay-[3500ms]">
                            <div>Compute provisioned: <span class="text-white">$0.00</span></div>
                            <div>Wall time: <span class="text-white">0.04s</span></div>
                        </div>
                        
                        <div class="mt-2 text-gray-500 animate-[pulse_1s_ease-in-out_infinite] delay-[4500ms]">_</div>
                    </div>
                </div>
            </div>
            
        </div>
    </div>
</body>
</html>

<script>
    const form = document.querySelector('#waitlist-form') as HTMLFormElement;
    const input = form?.querySelector('input') as HTMLInputElement;
    const btn = form?.querySelector('button') as HTMLButtonElement;
    const errorMsg = document.querySelector('#waitlist-error') as HTMLElement;
    const successBox = document.querySelector('#waitlist-success') as HTMLElement;

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        btn.disabled = true;
        btn.textContent = "Loading...";
        errorMsg.classList.add('hidden');
        
        try {
            const res = await fetch('/api/waitlist', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email: input.value })
            });
            
            if (!res.ok) {
                const data = await res.json();
                throw new Error(data.error || 'Failed to submit');
            }

            // Success Transition
            form.style.display = 'none';
            successBox.classList.remove('hidden');
            
        } catch (err: any) {
            errorMsg.textContent = err.message || "Something went wrong";
            errorMsg.classList.remove('hidden');
            btn.disabled = false;
            btn.textContent = "Join Waitlist";
        }
    });
</script>
